<UserControl x:Class="LLC_MOD_Toolbox.Views.Controls.SkinPageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid x:Name="SkinPage"
          Visibility="{Binding IsSkinPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Label HorizontalAlignment="Center" Margin="0,21,0,0" VerticalAlignment="Top" Height="55" Width="644" FontSize="15" Foreground="#FFFFEED4" FontFamily="/Fonts/subset/#Source Han Sans CN" FontWeight="Medium">
            <TextBlock Text="选择皮肤，其将立刻生效并作用于下次启动。" Height="45"/>
        </Label>
        <Label HorizontalAlignment="Center" Margin="0,49,0,0" VerticalAlignment="Top" Height="55" Width="644" FontSize="20" Foreground="#FFFFEED4" FontFamily="/Fonts/subset/#Source Han Sans CN" FontWeight="Bold">
            <TextBlock Text="皮肤选择" Height="45"/>
        </Label>
        <ComboBox x:Name="SkinBox" Margin="108,54,266,311" FontFamily="/Fonts/subset/#Source Han Sans CN" FontWeight="Medium" Foreground="Black" FontSize="16" ItemsSource="{Binding SkinOptions}" SelectedItem="{Binding SelectedSkinOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <ComboBox.Clip>
                <RectangleGeometry Rect="0,0,290,31" RadiusX="3" RadiusY="3"/>
            </ComboBox.Clip>
        </ComboBox>
        <Label x:Name="SkinDesc" HorizontalAlignment="Center" Margin="0,85,0,0" VerticalAlignment="Top" Height="55" Width="644" FontSize="15" Foreground="#FFFFEED4" FontFamily="/Fonts/subset/#Source Han Sans CN" FontWeight="Medium">
            <TextBlock Text="{Binding SkinDescription}" TextWrapping="Wrap" Height="45"/>
        </Label>
    </Grid>
</UserControl>

