<UserControl x:Class="LLC_MOD_Toolbox.Views.Controls.SkinPageControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid x:Name="SkinPage"
          Visibility="{Binding IsSkinPageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Label HorizontalAlignment="Center" Margin="0,21,0,0" VerticalAlignment="Top" Height="55" Width="644" FontSize="15" Foreground="#FFFFEED4" FontFamily="/Fonts/subset/#Source Han Sans CN" FontWeight="Medium">
            <TextBlock Text="选择皮肤，其将立刻生效并作用于下次启动。" Height="45"/>
        </Label>
        <Label HorizontalAlignment="Center" Margin="0,49,0,0" VerticalAlignment="Top" Height="55" Width="644" FontSize="20" Foreground="#FFFFEED4" FontFamily="/Fonts/subset/#Source Han Sans CN" FontWeight="Bold">
            <TextBlock Text="皮肤选择" Height="45"/>
        </Label>
        <ComboBox x:Name="SkinBox" Margin="108,54,266,311" FontFamily="/Fonts/subset/#Source Han Sans CN" FontWeight="Medium" Foreground="Black" FontSize="16" ItemsSource="{Binding SkinOptions}" SelectedItem="{Binding SelectedSkinOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="DisplayText">
            <ComboBox.Clip>
                <RectangleGeometry Rect="0,0,290,31" RadiusX="3" RadiusY="3"/>
            </ComboBox.Clip>
        </ComboBox>
        <Label x:Name="SkinDesc" HorizontalAlignment="Center" Margin="0,85,0,0" VerticalAlignment="Top" Height="300" Width="644" HorizontalContentAlignment="Stretch" FontSize="15" Foreground="#FFFFEED4" FontFamily="/Fonts/subset/#Source Han Sans CN" FontWeight="Medium">
            <TextBlock Text="{Binding SkinDescription}" TextWrapping="Wrap"/>
        </Label>
        <Label x:Name="SkinMusicText" Content="{Binding SkinMusicButtonText}" Visibility="{Binding IsSkinMusicAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" HorizontalAlignment="Left" IsHitTestVisible="False" Panel.ZIndex="10" Margin="518,53,0,0" VerticalAlignment="Top" Height="31" Width="71" FontSize="14" Foreground="Black" FontFamily="/Fonts/subset/#Source Han Sans CN" FontWeight="Heavy"/>
        <Image x:Name="SkinMusicHover" Visibility="{Binding IsSkinMusicAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="5" IsHitTestVisible="False" Opacity="0" HorizontalAlignment="Left" Height="34" Margin="511,52,0,0" VerticalAlignment="Top" Width="80" Source="pack://siteoforigin:,,,/Picture/SettingButtonHover.png"/>
        <Button x:Name="SkinMusicButton" Visibility="{Binding IsSkinMusicAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" Command="{Binding ToggleSkinMusicCommand}" HorizontalAlignment="Left" Margin="514,54,0,0" VerticalAlignment="Top" Height="28" Width="74" Style="{DynamicResource NoHover}" Background="#FFFFEED4">
            <Button.Clip>
                <RectangleGeometry Rect="0,0,74,28" RadiusX="3" RadiusY="3"/>
            </Button.Clip>
            <Button.Triggers>
                <EventTrigger RoutedEvent="Button.MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="SkinMusicHover" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="Button.MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="SkinMusicHover" Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.3"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Button.Triggers>
        </Button>
    </Grid>
</UserControl>

