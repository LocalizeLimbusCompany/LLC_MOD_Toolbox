        <Label x:Name="GachaText5" Visibility="Collapsed" HorizontalAlignment="Left" IsHitTestVisible="False" Margin="124,148,0,0" VerticalAlignment="Top" Height="28" Width="357" HorizontalContentAlignment="Center"><Label.Content><TextBlock Text="[★★]边狱公司EGO::罪人 希斯克利夫" FontSize="14" Foreground="#B88345" FontFamily="/Fonts/subset/#Source Han Sans CN" FontWeight="Bold"/></Label.Content></Label>
