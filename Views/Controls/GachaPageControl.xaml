        <Label x:Name="GachaText9" Visibility="Collapsed" HorizontalAlignment="Left" IsHitTestVisible="False" Margin="124,216,0,0" VerticalAlignment="Top" Height="28" Width="357" HorizontalContentAlignment="Center"><Label.Content><TextBlock Text="[★★]边狱公司EGO::罪人 希斯克利夫" FontSize="14" Foreground="#B88345" FontFamily="/Fonts/subset/#Source Han Sans CN" FontWeight="Bold"/></Label.Content></Label>
        <Label x:Name="GachaText10" Visibility="Collapsed" HorizontalAlignment="Left" IsHitTestVisible="False" Margin="124,232,0,0" VerticalAlignment="Top" Height="28" Width="357" HorizontalContentAlignment="Center"><Label.Content><TextBlock Text="[★★]边狱公司EGO::罪人 希斯克利夫" FontSize="14" Foreground="#B88345" FontFamily="/Fonts/subset/#Source Han Sans CN" FontWeight="Bold"/></Label.Content></Label>
    </Grid>
</UserControl>

