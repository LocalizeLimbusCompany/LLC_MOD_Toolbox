<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="LLC_MOD_Toolbox.Views.AgreementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="用户协议与隐私协议"
        Width="620"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F3F6FA"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        AutomationProperties.AutomationId="AgreementDialog">
    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#F7FAFF"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DCE4F0"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1D2530"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#5B6675"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#1F5FBF"/>
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#174A94"/>
        <SolidColorBrush x:Key="DangerTextBrush" Color="#8A2A2A"/>
        <SolidColorBrush x:Key="DisabledFillBrush" Color="#D8DEE8"/>

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.76"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource DisabledFillBrush}"/>
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{StaticResource DisabledFillBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProtocolButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="MinHeight" Value="64"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Width" Value="88"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#C8D1DD"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Width" Value="118"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Border Margin="18"
            Padding="26"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="继续使用前，请确认协议"
                           FontSize="22"
                           FontWeight="SemiBold"/>
                <TextBlock Text="请先阅读用户协议与隐私协议。若不同意或关闭此窗口，工具箱将退出。"
                           Margin="0,8,0,0"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           LineHeight="20"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource ProtocolButtonStyle}"
                        AutomationProperties.AutomationId="OpenUserAgreementButton"
                        Click="OpenUserAgreementClick">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="用户协议"
                                       FontWeight="SemiBold"
                                       FontSize="14"/>
                            <TextBlock Text="zeroasso.top/blog/2026/4/11/"
                                       Margin="0,5,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="打开"
                                   Margin="12,0,0,0"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Button>

                <Button Grid.Column="2"
                        Style="{StaticResource ProtocolButtonStyle}"
                        AutomationProperties.AutomationId="OpenPrivacyAgreementButton"
                        Click="OpenPrivacyAgreementClick">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="隐私协议"
                                       FontWeight="SemiBold"
                                       FontSize="14"/>
                            <TextBlock Text="zeroasso.top/blog/2026/4/11/2"
                                       Margin="0,5,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="打开"
                                   Margin="12,0,0,0"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Button>
            </Grid>

            <Border Grid.Row="2"
                    Margin="0,0,0,18"
                    Padding="16"
                    Background="#FFFDF8"
                    BorderBrush="#E7D8B8"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <CheckBox x:Name="UserAgreementCheckBox"
                              AutomationProperties.AutomationId="UserAgreementCheckBox"
                              Margin="0,0,0,12"
                              Checked="AgreementCheckChanged"
                              Unchecked="AgreementCheckChanged">
                        <TextBlock Text="我已阅读并同意用户协议"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                    </CheckBox>
                    <CheckBox x:Name="PrivacyAgreementCheckBox"
                              AutomationProperties.AutomationId="PrivacyAgreementCheckBox"
                              Checked="AgreementCheckChanged"
                              Unchecked="AgreementCheckChanged">
                        <TextBlock Text="我已阅读并同意隐私协议"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                    </CheckBox>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="3"
                       Text="同意后将继续启动工具箱。首次启动遥测仅包含 GUID、软件版本、系统版本。"
                       Margin="0,0,0,18"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       LineHeight="20"/>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="未勾选两个选项前无法继续。"
                           Foreground="{StaticResource DangerTextBrush}"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="退出"
                            Style="{StaticResource SecondaryButtonStyle}"
                            AutomationProperties.AutomationId="RejectButton"
                            IsCancel="True"
                            Click="RejectClick"/>
                    <Button x:Name="AgreeButton"
                            Content="同意并继续"
                            Style="{StaticResource PrimaryButtonStyle}"
                            AutomationProperties.AutomationId="AgreeButton"
                            Margin="10,0,0,0"
                            IsDefault="True"
                            IsEnabled="False"
                            Click="AgreeClick"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
